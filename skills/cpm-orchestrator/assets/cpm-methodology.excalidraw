    { "type": "line", "id": "footer_div", "x": 0, "y": 960, "width": 2400, "height": 0, "strokeColor": "#cbd5e1", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 600001, "version": 1, "versionNonce": 600002, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "points": [[0,0],[2400,0]] },
    { "type": "text", "id": "footer_q1", "x": 80, "y": 976, "width": 600, "height": 18, "text": "\"Context as Currency — treating context with BMAD rigor unlocks Hollywood-scale storytelling.\"", "originalText": "\"Context as Currency — treating context with BMAD rigor unlocks Hollywood-scale storytelling.\"", "fontSize": 12, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#64748b", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 600003, "version": 1, "versionNonce": 600004, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },
    { "type": "text", "id": "footer_q2", "x": 780, "y": 976, "width": 540, "height": 18, "text": "\"Automating the Boredom — agents handle rigid discipline; humans provide soul.\"", "originalText": "\"Automating the Boredom — agents handle rigid discipline; humans provide soul.\"", "fontSize": 12, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#64748b", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 600005, "version": 1, "versionNonce": 600006, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },
    { "type": "text", "id": "footer_q3", "x": 1420, "y": 976, "width": 500, "height": 18, "text": "\"Studio-in-a-Box — democratization of the blockbuster. Crew of 200 → crew of 1.\"", "originalText": "\"Studio-in-a-Box — democratization of the blockbuster. Crew of 200 → crew of 1.\"", "fontSize": 12, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#64748b", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 600007, "version": 1, "versionNonce": 600008, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 }
